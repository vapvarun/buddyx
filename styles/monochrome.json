{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"title": "Monochrome",
	"settings": {
		"color": {
			"palette": [
				{ "slug": "base",       "color": "#FFFFFF", "name": "Base" },
				{ "slug": "base-2",     "color": "#F5F5F5", "name": "Base 2" },
				{ "slug": "base-3",     "color": "#E5E5E5", "name": "Base 3" },
				{ "slug": "contrast",   "color": "#171717", "name": "Contrast" },
				{ "slug": "contrast-2", "color": "#404040", "name": "Contrast 2" },
				{ "slug": "contrast-3", "color": "#737373", "name": "Contrast 3" },
				{ "slug": "accent",     "color": "#262626", "name": "Charcoal" },
				{ "slug": "accent-2",   "color": "#525252", "name": "Stone" },
				{ "slug": "accent-3",   "color": "#A3A3A3", "name": "Pebble" },
				{ "slug": "surface-1",  "color": "#FAFAFA", "name": "Surface 1" },
				{ "slug": "surface-2",  "color": "#EFEFEF", "name": "Surface 2" },
				{ "slug": "surface-3",  "color": "#262626", "name": "Surface Dark" }
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast)"
		},
		"elements": {
			"link": {
				"color": { "text": "var(--wp--preset--color--contrast)" },
				":hover": { "color": { "text": "var(--wp--preset--color--contrast-2)" } }
			}
		}
	}
}
